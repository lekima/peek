<Window x:Class="Peek.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="420"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#161616"
        Foreground="#F2F2F2">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#FFE6E6E6" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#FF9A9A9A" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="68" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Foreground" Value="#FFEDEDED" />
            <Setter Property="Background" Value="#FF252525" />
            <Setter Property="BorderBrush" Value="#FF3C3C3C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF303030" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FF555555" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF1F1F1F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="68" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Foreground" Value="#FF161616" />
            <Setter Property="Background" Value="#FFFFD84D" />
            <Setter Property="BorderBrush" Value="#FFFFD84D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFFFE47A" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FFFFE47A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFE6BE32" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FFE6BE32" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="5,0" />
            <Setter Property="Background" Value="#FF202020" />
            <Setter Property="Foreground" Value="#FFF2F2F2" />
            <Setter Property="BorderBrush" Value="#FF3C3C3C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FFFFD84D" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FF555555" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="5,0" />
            <Setter Property="Background" Value="#FF202020" />
            <Setter Property="Foreground" Value="#FFF2F2F2" />
            <Setter Property="BorderBrush" Value="#FF3C3C3C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FFFFD84D" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FF555555" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SegmentButton" TargetType="RadioButton">
            <Setter Property="Height" Value="32" />
            <Setter Property="Foreground" Value="#FFEDEDED" />
            <Setter Property="Background" Value="#FF202020" />
            <Setter Property="BorderBrush" Value="#FF3C3C3C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF252525" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FF555555" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFFFD84D" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FFFFD84D" />
                                <Setter Property="Foreground" Value="#FF161616" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFE6E6E6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Box"
                                    Width="16"
                                    Height="16"
                                    Background="#FF202020"
                                    BorderBrush="#FF3C3C3C"
                                    BorderThickness="1"
                                    CornerRadius="3">
                                <Path x:Name="Check"
                                      Margin="3"
                                      Stroke="#FF161616"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="M 1 5 L 4 8 L 10 1"
                                      Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter Grid.Column="2"
                                              VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#FF555555" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#FFFFD84D" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="#FFFFD84D" />
                                <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Margin="18" LastChildFill="True">
        <Grid DockPanel.Dock="Bottom"
              Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <Button Content="Log"
                        Margin="0,0,8,0"
                        Click="OpenLog_Click" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal">
                <Button Content="Cancel"
                        Margin="0,0,8,0"
                        Click="Cancel_Click" />
                <Button Content="Save"
                        Style="{StaticResource PrimaryButton}"
                        IsDefault="True"
                        Click="Save_Click" />
            </StackPanel>
        </Grid>

        <StackPanel>
            <TextBlock Text="OpenRouter API key"
                       Style="{StaticResource MutedText}" />
            <PasswordBox x:Name="ApiKeyBox"
                         Margin="0,6,0,0"
                         PasswordChar="*" />

            <TextBlock Margin="0,16,0,0"
                       Text="Result format"
                       Style="{StaticResource MutedText}" />
            <UniformGrid Margin="0,6,0,0"
                         Columns="2">
                <RadioButton x:Name="TextFormatButton"
                             Margin="0,0,4,0"
                             Content="Text"
                             GroupName="ResultFormat"
                             Style="{StaticResource SegmentButton}" />
                <RadioButton x:Name="ImageFormatButton"
                             Margin="4,0,0,0"
                             Content="Image"
                             GroupName="ResultFormat"
                             Style="{StaticResource SegmentButton}" />
            </UniformGrid>

            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="From"
                               Style="{StaticResource MutedText}" />
                    <TextBox x:Name="FromLanguageBox"
                             Margin="0,6,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="To"
                               Style="{StaticResource MutedText}" />
                    <TextBox x:Name="ToLanguageBox"
                             Margin="0,6,0,0" />
                </StackPanel>
            </Grid>

            <CheckBox x:Name="StartupBox"
                      Margin="0,16,0,0"
                      Content="Run on Windows startup" />
        </StackPanel>
    </DockPanel>
</Window>
