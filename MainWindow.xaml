<Window x:Class="Peek.MainWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Peek"
        Icon="Resources/AppIcon.ico"
        Height="24"
        Width="84"
        MinHeight="24"
        MinWidth="84"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        FontFamily="pack://application:,,,/Resources/Fonts/#Roboto"
        WindowStartupLocation="CenterScreen"
        SourceInitialized="Window_SourceInitialized"
        Loaded="Window_Loaded">
    <Window.Resources>
        <ContextMenu x:Key="WindowMenu" Opened="WindowMenu_Opened">
            <Separator />
            <MenuItem Header="Settings" Click="SettingsMenu_Click" />
            <MenuItem Header="Quit" Click="QuitMenu_Click" />
        </ContextMenu>

        <Style x:Key="OverlayButton" TargetType="Button">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="#DDFFC65F" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFFFC65F" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFFFC65F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchButton" TargetType="Button" BasedOn="{StaticResource OverlayButton}">
            <Setter Property="Foreground" Value="#E6080808" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="ToolTip" Value="Search" />
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <Border x:Name="FrameBorder"
                Margin="0,22,4,22"
                BorderBrush="#CCFFC65F"
                BorderThickness="1"
                CornerRadius="4"
                Background="Transparent"
                Visibility="Collapsed"
                IsHitTestVisible="True">
            <Grid>
                <Border x:Name="ResultPanel"
                        Margin="0"
                        Padding="16,12"
                        Background="#E6111111"
                        CornerRadius="3"
                        ClipToBounds="True"
                        SnapsToDevicePixels="True"
                        Visibility="Collapsed"
                        SizeChanged="ResultPanel_SizeChanged">
                    <Grid>
                        <StackPanel x:Name="ResultTextPanel"
                                    Visibility="Collapsed">
                            <StackPanel.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="pack://application:,,,/Resources/Fonts/#Roboto Condensed" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Foreground" Value="#FFFFC65F" />
                                    <Setter Property="TextWrapping" Value="Wrap" />
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                </Style>
                            </StackPanel.Resources>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <StackPanel Margin="0,2,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Orientation="Horizontal">
            <Button x:Name="DragButton"
                    Margin="0,0,4,0"
                    Style="{StaticResource OverlayButton}"
                    ContextMenu="{StaticResource WindowMenu}"
                    PreviewMouseLeftButtonDown="DragButton_MouseLeftButtonDown"
                    PreviewMouseMove="DragButton_MouseMove"
                    PreviewMouseLeftButtonUp="DragButton_MouseLeftButtonUp">
                <Grid Width="10"
                      Height="10">
                    <Ellipse Width="1.6"
                             Height="1.6"
                             Margin="2,2,0,0"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top"
                             Fill="#E6080808" />
                    <Ellipse Width="1.6"
                             Height="1.6"
                             Margin="6.4,2,0,0"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top"
                             Fill="#E6080808" />
                    <Ellipse Width="1.6"
                             Height="1.6"
                             Margin="2,6.4,0,0"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top"
                             Fill="#E6080808" />
                    <Ellipse Width="1.6"
                             Height="1.6"
                             Margin="6.4,6.4,0,0"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top"
                             Fill="#E6080808" />
                </Grid>
            </Button>

            <Button x:Name="TranslateButton"
                    Margin="0,0,4,0"
                    Style="{StaticResource OverlayButton}"
                    Click="TranslateButton_Click">
                <Grid Width="10"
                      Height="10">
                    <Path x:Name="TranslateIcon"
                          Fill="#E6080808"
                          Data="M 2.5 1.5 L 8 5 L 2.5 8.5 Z" />
                    <Grid x:Name="TranslateSpinner"
                          Width="8"
                          Height="8"
                          Visibility="Collapsed"
                          RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <RotateTransform x:Name="TranslateSpinnerRotate" Angle="0" />
                    </Grid.RenderTransform>
                    <Path Stroke="#E6080808"
                          StrokeThickness="1.3"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Data="M 4 0.9 A 3.1 3.1 0 1 1 1.8 6.2" />
                    </Grid>
                </Grid>
            </Button>

            <Button x:Name="ClearButton"
                    Margin="0,0,4,0"
                    Style="{StaticResource OverlayButton}"
                    Click="ClearButton_Click">
                <Grid Width="10"
                      Height="10">
                    <Path Stroke="#E6080808"
                          StrokeThickness="1.6"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Data="M 2 2 L 8 8 M 8 2 L 2 8" />
                </Grid>
            </Button>

            <Button x:Name="ResizeRowButton"
                    Style="{StaticResource OverlayButton}"
                    PreviewMouseLeftButtonDown="ResizeButton_MouseLeftButtonDown"
                    PreviewMouseMove="ResizeButton_MouseMove"
                    PreviewMouseLeftButtonUp="ResizeButton_MouseLeftButtonUp">
                <Grid Width="10"
                      Height="10">
                    <Path Stroke="#E6080808"
                          StrokeThickness="1.6"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Data="M 2 8 L 8 8 L 8 2" />
                </Grid>
            </Button>
        </StackPanel>

        <Border x:Name="StatusLabel"
                Margin="0,2,4,0"
                Padding="6,0"
                MinHeight="18"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="#DDFFC65F"
                CornerRadius="3"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Foreground="#FF080808"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis" />
        </Border>

        <StackPanel x:Name="SearchButtonsPanel"
                    Margin="0,0,0,2"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal"
                    Visibility="Collapsed">
            <Button x:Name="SearchButton1"
                    Margin="0,0,4,0"
                    Style="{StaticResource SearchButton}"
                    Content="1"
                    Click="SearchButton_Click" />
            <Button x:Name="SearchButton2"
                    Margin="0,0,4,0"
                    Style="{StaticResource SearchButton}"
                    Content="2"
                    Visibility="Collapsed"
                    Click="SearchButton_Click" />
            <Button x:Name="SearchButton3"
                    Style="{StaticResource SearchButton}"
                    Content="3"
                    Visibility="Collapsed"
                    Click="SearchButton_Click" />
        </StackPanel>

        <Button x:Name="ResizeCornerButton"
                Margin="0,0,4,2"
                Style="{StaticResource OverlayButton}"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Visibility="Collapsed"
                PreviewMouseLeftButtonDown="ResizeButton_MouseLeftButtonDown"
                PreviewMouseMove="ResizeButton_MouseMove"
                PreviewMouseLeftButtonUp="ResizeButton_MouseLeftButtonUp">
            <Grid Width="10"
                  Height="10">
                <Path Stroke="#E6080808"
                      StrokeThickness="1.6"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Data="M 2 8 L 8 8 L 8 2" />
            </Grid>
        </Button>

    </Grid>
</Window>
