<Window x:Class="Peek.MainWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Peek"
        Icon="Resources/AppIcon.ico"
        Height="24"
        Width="84"
        MinHeight="24"
        MinWidth="84"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        FontFamily="pack://application:,,,/Resources/Fonts/#Roboto"
        WindowStartupLocation="CenterScreen"
        SourceInitialized="Window_SourceInitialized"
        Loaded="Window_Loaded">
    <Window.Resources>
        <ContextMenu x:Key="WindowMenu">
            <MenuItem Header="Settings" Click="SettingsMenu_Click" />
            <MenuItem Header="Quit" Click="QuitMenu_Click" />
        </ContextMenu>
    </Window.Resources>

    <Grid Background="Transparent">
        <Border x:Name="FrameBorder"
                Margin="0,22,4,22"
                BorderBrush="#CCFFC65F"
                BorderThickness="1"
                CornerRadius="4"
                Background="Transparent"
                Visibility="Collapsed"
                IsHitTestVisible="True">
            <Grid>
                <Border x:Name="ResultPanel"
                        Margin="0"
                        Padding="16,12"
                        Background="#E6111111"
                        CornerRadius="3"
                        ClipToBounds="True"
                        SnapsToDevicePixels="True"
                        Visibility="Collapsed"
                        SizeChanged="ResultPanel_SizeChanged">
                    <Grid>
                        <Image x:Name="ResultImage"
                               Stretch="Fill"
                               Visibility="Collapsed"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <StackPanel x:Name="ResultTextPanel"
                                    Visibility="Collapsed">
                            <StackPanel.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="pack://application:,,,/Resources/Fonts/#Roboto Condensed" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Foreground" Value="#FFFFC65F" />
                                    <Setter Property="TextWrapping" Value="Wrap" />
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                </Style>
                            </StackPanel.Resources>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <StackPanel Margin="0,2,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Orientation="Horizontal">
            <Button x:Name="DragButton"
                    Width="18"
                    Height="18"
                    Margin="0,0,4,0"
                    Padding="0"
                    Focusable="False"
                    FocusVisualStyle="{x:Null}"
                    ContextMenu="{StaticResource WindowMenu}"
                    PreviewMouseLeftButtonDown="DragButton_MouseLeftButtonDown"
                    PreviewMouseMove="DragButton_MouseMove"
                    PreviewMouseLeftButtonUp="DragButton_MouseLeftButtonUp">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Circle"
                                Background="#DDFFC65F"
                                BorderThickness="0"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Circle" Property="Background" Value="#FFFFC65F" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Circle" Property="Background" Value="#FFFFC65F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <Grid Width="10"
                      Height="10">
                    <Ellipse Width="1.6"
                             Height="1.6"
                             Margin="2,2,0,0"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top"
                             Fill="#E6080808" />
                    <Ellipse Width="1.6"
                             Height="1.6"
                             Margin="6.4,2,0,0"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top"
                             Fill="#E6080808" />
                    <Ellipse Width="1.6"
                             Height="1.6"
                             Margin="2,6.4,0,0"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top"
                             Fill="#E6080808" />
                    <Ellipse Width="1.6"
                             Height="1.6"
                             Margin="6.4,6.4,0,0"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top"
                             Fill="#E6080808" />
                </Grid>
            </Button>

            <Button x:Name="TranslateButton"
                    Width="18"
                    Height="18"
                    Margin="0,0,4,0"
                    Padding="0"
                    Focusable="False"
                    FocusVisualStyle="{x:Null}"
                    Click="TranslateButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Circle"
                                Background="#DDFFC65F"
                                BorderThickness="0"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Circle" Property="Background" Value="#FFFFC65F" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Circle" Property="Background" Value="#FFFFC65F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <Grid Width="10"
                      Height="10">
                    <Path x:Name="TranslateIcon"
                          Fill="#E6080808"
                          Data="M 2.5 1.5 L 8 5 L 2.5 8.5 Z" />
                    <Grid x:Name="TranslateSpinner"
                          Width="8"
                          Height="8"
                          Visibility="Collapsed"
                          RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <RotateTransform x:Name="TranslateSpinnerRotate" Angle="0" />
                    </Grid.RenderTransform>
                    <Path Stroke="#E6080808"
                          StrokeThickness="1.3"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Data="M 4 0.9 A 3.1 3.1 0 1 1 1.8 6.2" />
                    </Grid>
                </Grid>
            </Button>

            <Button x:Name="ClearButton"
                    Width="18"
                    Height="18"
                    Margin="0,0,4,0"
                    Padding="0"
                    Focusable="False"
                    FocusVisualStyle="{x:Null}"
                    Click="ClearButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Circle"
                                Background="#DDFFC65F"
                                BorderThickness="0"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Circle" Property="Background" Value="#FFFFC65F" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Circle" Property="Background" Value="#FFFFC65F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <Grid Width="10"
                      Height="10">
                    <Path Stroke="#E6080808"
                          StrokeThickness="1.6"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Data="M 2 2 L 8 8 M 8 2 L 2 8" />
                </Grid>
            </Button>

            <Button x:Name="ResizeRowButton"
                    Width="18"
                    Height="18"
                    Padding="0"
                    Focusable="False"
                    FocusVisualStyle="{x:Null}"
                    PreviewMouseLeftButtonDown="ResizeButton_MouseLeftButtonDown"
                    PreviewMouseMove="ResizeButton_MouseMove"
                    PreviewMouseLeftButtonUp="ResizeButton_MouseLeftButtonUp">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Circle"
                                Background="#DDFFC65F"
                                BorderThickness="0"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Circle" Property="Background" Value="#FFFFC65F" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Circle" Property="Background" Value="#FFFFC65F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <Grid Width="10"
                      Height="10">
                    <Path Stroke="#E6080808"
                          StrokeThickness="1.6"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Data="M 2 8 L 8 8 L 8 2" />
                </Grid>
            </Button>
        </StackPanel>

        <Border x:Name="StatusLabel"
                Margin="0,2,4,0"
                Padding="6,0"
                MinHeight="18"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="#DDFFC65F"
                CornerRadius="3"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Foreground="#FF080808"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis" />
        </Border>

        <StackPanel x:Name="SearchButtonsPanel"
                    Margin="0,0,0,2"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal"
                    Visibility="Collapsed">
            <Button x:Name="SearchButton1"
                    Width="18"
                    Height="18"
                    Margin="0,0,4,0"
                    Padding="0"
                    Content="1"
                    FontSize="11"
                    FontWeight="Bold"
                    Focusable="False"
                    FocusVisualStyle="{x:Null}"
                    ToolTip="Search"
                    Click="SearchButton_Click" />
            <Button x:Name="SearchButton2"
                    Width="18"
                    Height="18"
                    Margin="0,0,4,0"
                    Padding="0"
                    Content="2"
                    FontSize="11"
                    FontWeight="Bold"
                    Focusable="False"
                    FocusVisualStyle="{x:Null}"
                    ToolTip="Search"
                    Visibility="Collapsed"
                    Click="SearchButton_Click" />
            <Button x:Name="SearchButton3"
                    Width="18"
                    Height="18"
                    Padding="0"
                    Content="3"
                    FontSize="11"
                    FontWeight="Bold"
                    Focusable="False"
                    FocusVisualStyle="{x:Null}"
                    ToolTip="Search"
                    Visibility="Collapsed"
                    Click="SearchButton_Click" />
            <StackPanel.Resources>
                <Style TargetType="Button">
                    <Setter Property="Foreground" Value="#E6080808" />
                    <Setter Property="Background" Value="#DDFFC65F" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Circle"
                                        Background="{TemplateBinding Background}"
                                        BorderThickness="0"
                                        CornerRadius="3">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Circle" Property="Background" Value="#FFFFC65F" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Circle" Property="Background" Value="#FFFFC65F" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </StackPanel.Resources>
        </StackPanel>

        <Button x:Name="ResizeCornerButton"
                Width="18"
                Height="18"
                Margin="0,0,4,2"
                Padding="0"
                Focusable="False"
                FocusVisualStyle="{x:Null}"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Visibility="Collapsed"
                PreviewMouseLeftButtonDown="ResizeButton_MouseLeftButtonDown"
                PreviewMouseMove="ResizeButton_MouseMove"
                PreviewMouseLeftButtonUp="ResizeButton_MouseLeftButtonUp">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Circle"
                            Background="#DDFFC65F"
                            BorderThickness="0"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Circle" Property="Background" Value="#FFFFC65F" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Circle" Property="Background" Value="#FFFFC65F" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
            <Grid Width="10"
                  Height="10">
                <Path Stroke="#E6080808"
                      StrokeThickness="1.6"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Data="M 2 8 L 8 8 L 8 2" />
            </Grid>
        </Button>

    </Grid>
</Window>
